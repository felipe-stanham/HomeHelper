{
  "name": "example_full_app",
  "type": "service",
  "description": "Full-featured example app demonstrating all Latarnia P-0002 capabilities",
  "version": "1.0.0",
  "author": "Latarnia",
  "main_file": "app.py",
  "config": {
    "has_UI": true,
    "has_web_ui": true,
    "redis_required": true,
    "database": true,
    "mcp_server": true,
    "mcp_port": 9001,
    "logs_dir": true,
    "data_dir": true,
    "auto_start": false,
    "restart_policy": "always",
    "redis_streams_publish": ["example.events.created"],
    "redis_streams_subscribe": ["example.commands.process"]
  },
  "requires": [
    {"app": "example_companion", "min_version": "1.0.0"}
  ]
}
